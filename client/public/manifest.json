{
  "name": "E-TaxPay | Zila Panchayat Uttarakhand",
  "short_name": "E-TaxPay",
  "description": "Digital Shop Tax Collection System for Uttarakhand",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#000000",
  "theme_color": "#000000",
  "orientation": "portrait-primary",
  "scope": "/",
  "prefer_related_applications": false,
  "categories": ["finance", "government"],
  "shortcuts": [
    {
      "name": "Dashboard",
      "short_name": "Dashboard",
      "description": "View tax overview",
      "url": "/user/dashboard",
      "icons": [{ "src": "/logo.png", "sizes": "192x192" }]
    },
    {
      "name": "Pay Monthly Tax",
      "short_name": "Pay Tax",
      "description": "Quick tax payment",
      "url": "/user/monthly-tax",
      "icons": [{ "src": "/logo.png", "sizes": "192x192" }]
    }
  ],
  "permissions": [
    "notifications",
    "camera",
    "geolocation"
  ],
  "icons": [
    {
      "src": "/logo.png",
      "type": "image/png",
      "sizes": "192x192",
      "purpose": "any maskable"
    },
    {
      "src": "/logo.png",
      "type": "image/png",
      "sizes": "512x512",
      "purpose": "any maskable"
    }
  ]
}
